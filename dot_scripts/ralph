#!/usr/bin/env bash
set -uo pipefail

# ─── Config ───────────────────────────────────────────────────────────────────
MAX_ITERATIONS=${RALPH_MAX_ITERATIONS:-20}
MAX_CONSECUTIVE_FAILURES=${RALPH_MAX_FAILURES:-3}
AGENT=${RALPH_AGENT:-build}
AGENT_OUTPUT_LINES=${RALPH_OUTPUT_LINES:-50}  # lines of agent output passed to next prompt

RALPH_FILE=".agents/RALPH.md"
HANDOFF_FILE=".agents/HANDOFF.md"
HISTORY_DIR=".agents/history"

# ─── Output helpers ───────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log()  { echo -e "${BLUE}[ralph]${NC} $*"; }
ok()   { echo -e "${GREEN}[ralph]${NC} $*"; }
warn() { echo -e "${YELLOW}[ralph]${NC} $*"; }
err()  { echo -e "${RED}[ralph]${NC} $*"; }

# ─── Preflight checks ─────────────────────────────────────────────────────────
if ! git rev-parse --git-dir >/dev/null 2>&1; then
    err "Not a git repository. Run ralph from your project root."
    exit 1
fi

if ! command -v opencode >/dev/null 2>&1; then
    err "opencode not found in PATH."
    exit 1
fi

if ! command -v bd >/dev/null 2>&1; then
    err "Beads (bd) not found in PATH. ralph requires beads for task tracking."
    exit 1
fi

open_tasks=$(bd list --quiet 2>/dev/null | grep -c '.' || echo 0)
if [ "$open_tasks" -eq 0 ]; then
    err "No open Beads tasks found. Run /prepare-backlog first to set up the project backlog."
    exit 1
fi
if [ "$open_tasks" -lt 3 ]; then
    err "Only $open_tasks open task(s) found. Ralph is designed for multi-iteration projects — use /dev for small scoped work."
    exit 1
fi

# ─── Helpers ──────────────────────────────────────────────────────────────────
parse_status() {
    echo "$1" | sed 's/iteration [0-9]*: //' | awk '{print $1}'
}

ensure_newline() {
    [ -f "$1" ] && [ -n "$(tail -c1 "$1")" ] && echo >> "$1"
}

strip_ansi() {
    sed 's/\x1b\[[0-9;]*[a-zA-Z]//g'
}

# ─── Resume state from existing RALPH.md ──────────────────────────────────────
consecutive_failures=0
iteration=1
ralph_memory=""
agent_prev_output=""

if [ -f "$RALPH_FILE" ]; then
    ensure_newline "$RALPH_FILE"
    existing_lines=$(wc -l < "$RALPH_FILE")
    iteration=$((existing_lines + 1))
    ralph_memory=$(cat "$RALPH_FILE")

    last_status=$(parse_status "$(tail -1 "$RALPH_FILE")")

    if [ "$last_status" = "complete" ]; then
        ok "RALPH.md shows project already complete. Nothing to do."
        exit 0
    fi

    log "Resuming at iteration $iteration. Last status: $last_status"

    # Count consecutive failures from the end of file
    while IFS= read -r line; do
        s=$(parse_status "$line")
        if [ "$s" = "failed" ]; then
            ((consecutive_failures++)) || true
        else
            consecutive_failures=0
        fi
    done < "$RALPH_FILE"
else
    log "No RALPH.md found — starting fresh."
fi

log "Max iterations: $MAX_ITERATIONS | Max consecutive failures: $MAX_CONSECUTIVE_FAILURES"
echo ""

# ─── Main loop ────────────────────────────────────────────────────────────────
while [ "$iteration" -le "$MAX_ITERATIONS" ]; do

    if [ "$consecutive_failures" -ge "$MAX_CONSECUTIVE_FAILURES" ]; then
        err "$MAX_CONSECUTIVE_FAILURES consecutive failures reached. Stopping."
        err "Review .agents/HANDOFF.md for details."
        exit 1
    fi

    log "━━━ Iteration $iteration / $MAX_ITERATIONS ━━━"

    # Snapshot HANDOFF before run
    sha_before=""
    [ -f "$HANDOFF_FILE" ] && sha_before=$(sha256sum "$HANDOFF_FILE" | cut -d' ' -f1)

    # Build prompt — include previous status and agent's last output
    if [ "$iteration" -eq 1 ]; then
        prev_status="none (first iteration)"
    else
        prev_status=$(parse_status "$(tail -1 "$RALPH_FILE")")
    fi

    prompt="Iteration $iteration. Previous: $prev_status."
    if [ -n "$agent_prev_output" ]; then
        prompt="$prompt Agent notes from last iteration: $agent_prev_output"
    fi
    if [ -n "${handoff_note:-}" ]; then
        prompt="$prompt $handoff_note"
    fi

    # Run opencode — stream live to terminal, capture to temp file
    mkdir -p "$HISTORY_DIR"
    tmp_out=$(mktemp)
    opencode run --agent "$AGENT" --command ralph-loop "$prompt" 2>&1 | tee "$tmp_out" || true
    agent_output=$(cat "$tmp_out")
    rm -f "$tmp_out"
    echo ""

    # Save raw output to history
    echo "$agent_output" | strip_ansi > "$HISTORY_DIR/output-${iteration}.txt"

    # Extract last lines for next iteration's prompt (strip ANSI, skip blank lines)
    agent_prev_output=$(echo "$agent_output" | strip_ansi | grep -v '^\s*$' | tail -"$AGENT_OUTPUT_LINES")

    # ── Check RALPH.md first — it is the authoritative source ────────────────
    ralph_written=false

    if [ -f "$RALPH_FILE" ]; then
        ensure_newline "$RALPH_FILE"
        current_lines=$(wc -l < "$RALPH_FILE")

        if [ "$current_lines" -eq "$iteration" ]; then
            # Agent wrote their line
            ralph_written=true

        elif [ "$current_lines" -lt "$iteration" ]; then
            # Agent didn't write their line — genuine stall
            warn "Agent did not write to RALPH.md."

        else
            # More lines than expected — integrity issue
            warn "RALPH.md has too many lines (expected $iteration, got $current_lines). Restoring from memory."
            if [ -n "$ralph_memory" ]; then
                echo "$ralph_memory" > "$RALPH_FILE"
            fi
        fi
    else
        warn "RALPH.md not found after run."
    fi

    # ── RALPH.md history integrity check ────────────────────────────────────
    if $ralph_written && [ -n "$ralph_memory" ]; then
        prev_count=$(echo "$ralph_memory" | wc -l)
        if [ "$prev_count" -gt 1 ]; then
            expected_history=$(echo "$ralph_memory" | head -n $((prev_count - 1)))
            actual_history=$(head -n $((prev_count - 1)) "$RALPH_FILE")
            if [ "$expected_history" != "$actual_history" ]; then
                warn "RALPH.md history tampered — restoring from memory."
                echo "$ralph_memory" > "$RALPH_FILE"
                ralph_written=false
            fi
        fi
    fi

    # ── If agent didn't write RALPH.md, append stall failure ────────────────
    if ! $ralph_written; then
        echo "iteration $iteration: failed - agent stalled, no ralph entry written" >> "$RALPH_FILE"
        [ -f "$HANDOFF_FILE" ] && cp "$HANDOFF_FILE" "$HISTORY_DIR/handoff-${iteration}.md"
        ralph_memory=$(cat "$RALPH_FILE")
        ((consecutive_failures++)) || true
        ((iteration++)) || true
        continue
    fi

    # ── HANDOFF check — warning + inject context note into next prompt ───────
    sha_after=""
    [ -f "$HANDOFF_FILE" ] && sha_after=$(sha256sum "$HANDOFF_FILE" | cut -d' ' -f1)

    handoff_note=""
    if [ -z "$sha_after" ]; then
        warn "HANDOFF.md was not written. Injecting context note into next prompt."
        handoff_note="WARNING: previous iteration did not write HANDOFF.md. You have no structured handoff — use git log, PLAN.md, and RALPH.md to reconstruct context before proceeding."
    elif [ -n "$sha_before" ] && [ "$sha_before" = "$sha_after" ]; then
        warn "HANDOFF.md unchanged. Injecting context note into next prompt."
        handoff_note="WARNING: previous iteration did not update HANDOFF.md. It may be stale — cross-check with git log and PLAN.md before trusting it."
    fi

    # ── Parse and act on current iteration status ────────────────────────────
    current_line=$(tail -1 "$RALPH_FILE")
    current_status=$(parse_status "$current_line")
    complete_in_output=$(echo "$agent_output" | grep -c "^COMPLETE$" 2>/dev/null || echo 0)

    # Both signals agree on complete — done
    if [ "$current_status" = "complete" ] && [ "$complete_in_output" -gt 0 ]; then
        ok "Project complete after $iteration iterations (RALPH.md and output agree)."
        exit 0
    fi

    # RALPH says complete but output didn't signal — still trust RALPH, but log it
    if [ "$current_status" = "complete" ] && [ "$complete_in_output" -eq 0 ]; then
        ok "Project complete after $iteration iterations (RALPH.md). Note: agent did not output COMPLETE signal."
        exit 0
    fi

    # Output says COMPLETE but RALPH doesn't agree — run reconciliation iteration
    if [ "$complete_in_output" -gt 0 ] && [ "$current_status" != "complete" ]; then
        warn "Agent output COMPLETE but RALPH.md shows '$current_status'. Running reconciliation check."
        ((iteration++)) || true
        ralph_memory=$(cat "$RALPH_FILE")
        reconcile_prompt="RECONCILIATION: Iteration $((iteration - 1)) output the word COMPLETE but RALPH.md shows '$current_status'. Run the full completion check (tests, lint, git, PRD, beads). If the project is truly finished write 'iteration $iteration: complete' to RALPH.md and output COMPLETE. If not, write 'iteration $iteration: success' and continue normally."
        tmp_out=$(mktemp)
        opencode run --agent "$AGENT" --command ralph-loop "$reconcile_prompt" 2>&1 | tee "$tmp_out" || true
        agent_output=$(cat "$tmp_out")
        rm -f "$tmp_out"
        echo "$agent_output" | strip_ansi > "$HISTORY_DIR/output-${iteration}-reconcile.txt"
        agent_prev_output=$(echo "$agent_output" | strip_ansi | grep -v '^\s*$' | tail -"$AGENT_OUTPUT_LINES")
        echo ""

        ensure_newline "$RALPH_FILE"
        current_lines=$(wc -l < "$RALPH_FILE")
        if [ "$current_lines" -eq "$iteration" ]; then
            current_line=$(tail -1 "$RALPH_FILE")
            current_status=$(parse_status "$current_line")
            [ -f "$HANDOFF_FILE" ] && cp "$HANDOFF_FILE" "$HISTORY_DIR/handoff-${iteration}-reconcile.md"
            if [ "$current_status" = "complete" ]; then
                ok "Project complete after reconciliation."
                exit 0
            fi
            warn "Reconciliation result: $current_status. Continuing loop."
            ralph_memory=$(cat "$RALPH_FILE")
        elif [ "$current_lines" -gt "$iteration" ]; then
            warn "Reconciliation: RALPH.md has too many lines (expected $iteration, got $current_lines). Restoring from memory."
            if [ -n "$ralph_memory" ]; then
                echo "$ralph_memory" > "$RALPH_FILE"
            fi
            echo "iteration $iteration: failed - reconciliation stalled" >> "$RALPH_FILE"
            [ -f "$HANDOFF_FILE" ] && cp "$HANDOFF_FILE" "$HISTORY_DIR/handoff-${iteration}-reconcile.md"
            ralph_memory=$(cat "$RALPH_FILE")
            ((consecutive_failures++)) || true
        else
            warn "Reconciliation: agent did not write RALPH.md entry. Appending failure."
            echo "iteration $iteration: failed - reconciliation stalled" >> "$RALPH_FILE"
            [ -f "$HANDOFF_FILE" ] && cp "$HANDOFF_FILE" "$HISTORY_DIR/handoff-${iteration}-reconcile.md"
            ralph_memory=$(cat "$RALPH_FILE")
            ((consecutive_failures++)) || true
        fi
        ((iteration++)) || true
        echo ""
        continue
    fi

    case "$current_status" in
        success)
            ok "Iteration $iteration succeeded."
            consecutive_failures=0
            ;;
        failed)
            warn "Iteration $iteration failed: $current_line"
            ((consecutive_failures++)) || true
            ;;
        *)
            warn "Unexpected status '$current_status' in RALPH.md — treating as failure."
            ((consecutive_failures++)) || true
            ;;
    esac

    # Archive HANDOFF for this iteration
    if [ -f "$HANDOFF_FILE" ]; then
        cp "$HANDOFF_FILE" "$HISTORY_DIR/handoff-${iteration}.md"
    fi

    # Update in-memory copy
    ralph_memory=$(cat "$RALPH_FILE")

    ((iteration++)) || true
    echo ""
done

err "Maximum iterations ($MAX_ITERATIONS) reached. Stopping."
err "Review .agents/HANDOFF.md and .agents/RALPH.md for current state."
exit 1

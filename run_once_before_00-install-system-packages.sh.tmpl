#!/bin/bash

# Exit on error
set -e

{{- if eq .chezmoi.os "linux" }}
  {{- $id := .chezmoi.osRelease.id -}}
  {{- $idLike := (get .chezmoi.osRelease "idLike" | default "") -}}
  {{- if or (eq $id "ubuntu" "debian" "pop" "linuxmint") (contains "debian" $idLike) }}
  PACKAGES="curl git python3 make g++"
  REQUIRED_COMMANDS="curl git python3 make g++"
  INSTALL_CMD='sudo apt-get update && sudo apt-get install -y'
  {{- else if or (eq $id "fedora" "nobara" "rhel" "rocky" "almalinux" "centos") (contains "fedora" $idLike) (contains "rhel" $idLike) }}
  PACKAGES="curl git python3 make gcc-c++"
  REQUIRED_COMMANDS="curl git python3 make g++"
  INSTALL_CMD='sudo dnf install -y'
  {{- else if or (eq $id "arch" "manjaro") (contains "arch" $idLike) }}
  PACKAGES="curl git python3 make gcc"
  REQUIRED_COMMANDS="curl git python3 make g++"
  INSTALL_CMD='sudo pacman -S --noconfirm --needed'
  {{- else if or (eq $id "opensuse" "opensuse-tumbleweed") (contains "suse" $idLike) }}
  PACKAGES="curl git python3 make gcc-c++"
  REQUIRED_COMMANDS="curl git python3 make g++"
  INSTALL_CMD='sudo zypper install -y'
  {{- else }}
  echo "Unsupported distribution: {{ $id }}"
  exit 1
  {{- end }}

  # Function to check if a command exists
  exists() {
    command -v "$1" >/dev/null 2>&1
  }

  # Check if we need to install anything
  NEEDS_INSTALL=false
  for cmd in $REQUIRED_COMMANDS; do
    if ! exists "$cmd"; then
      NEEDS_INSTALL=true
      break
    fi
  done

  if [ "$NEEDS_INSTALL" = true ]; then
    echo "Installing system packages: $PACKAGES"
    eval "$INSTALL_CMD $PACKAGES"
  else
    echo "System packages already installed."
  fi
{{- end }}

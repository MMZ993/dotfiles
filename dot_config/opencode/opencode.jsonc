{
  "$schema": "https://opencode.ai/config.json",
    "plugin": ["@tarquinen/opencode-dcp", "cc-safety-net"],
    "mcp": {
        "cbm": {
            "type": "local",
            "command": ["cbm"]
        },
        "aidex": {
            "type": "local",
            "command": ["aidex"]
        },
        "serena": {
            "type": "local",
            "command": [
                "uvx",
                "--from",
                "git+https://github.com/oraios/serena",
                "serena",
                "start-mcp-server",
                "--context", "opencode",
                "--project", "."
            ]
        }
    },
    "agent": {
        "plan": {
            "disable": true
        },
        "general": {
            "disable": true
        }
    },
    "permission": {
        "aidex_*": "deny",
        "cbm_*": "deny",
        "serena_*": "deny"
    }
}

#!/bin/bash

# config.toml hash: {{ include "dot_config/mise/config.toml.tmpl" | sha256sum }}

# Exit on error
set -e

# Ensure mise is in the PATH for this script
export PATH="$HOME/.local/bin:$PATH"

if command -v mise >/dev/null 2>&1; then
    echo "Installing/Updating tools defined in mise config..."
    
    # Prevent aidex from injecting into AI client configs during npm install
    export AIDEX_NO_SETUP=1
    
    # Firecrawl no telemetry, api url and dummy api key
    export FIRECRAWL_NO_TELEMETRY=1
    export FIRECRAWL_API_URL=https://firecrawl.mmz.sh
    export FIRECRAWL_API_KEY=dummy_key
    # --yes skips confirmation prompts
    mise install --yes
else
    echo "Mise not found. Skipping tool installation."
fi
